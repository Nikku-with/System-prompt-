## 🔀 Strategy Router (Unpredictability Engine)

```python
import random
from langchain_core.prompts import ChatPromptTemplate

STRATEGIES = ["decompose", "hypothesis", "ooda", "heuristic", "socratic"]

def supervisor_node(state: AgentState) -> AgentState:
    """Pick a reasoning strategy dynamically based on goal type."""
    goal = state["goal"]

    strategy_prompt = ChatPromptTemplate.from_messages([
        ("system", """Classify this goal into ONE reasoning strategy:
          - decompose   : complex multi-step task, clear sub-goals
          - hypothesis  : uncertain outcome, needs testing/probing
          - ooda        : fast-changing environment, real-time data
          - heuristic   : pattern matches a known solved class
          - socratic    : ambiguous goal, needs clarifying questions first
         Return ONLY the strategy name. No explanation."""),
        ("human", "{goal}")
    ])

    chain = strategy_prompt | llm
    strategy = chain.invoke({"goal": goal}).content.strip().lower()

    if strategy not in STRATEGIES:
        strategy = random.choice(STRATEGIES)  # true unpredictability fallback

    return {**state, "strategy": strategy,
            "scratchpad": [f"[supervisor] strategy={strategy}"]}
```

