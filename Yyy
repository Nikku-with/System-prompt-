## 🪞 Reflection / Critic Node

```python
def reflection_node(state: AgentState) -> AgentState:
    recent_tools = state["tool_results"][-3:]
    
    critic_prompt = f"""
    Goal: {state['goal']}
    Last 3 actions: {recent_tools}
    Current plan step: {state['current_step']} / {len(state['plan'])}

    Rate progress 0.0–1.0 and identify:
    1. Any factual hallucinations?
    2. Is the plan still optimal?
    3. Should a human approve the next step? (yes/no)

    Return JSON: {{"score": float, "issues": [], "needs_human": bool, "revised_plan": []}}
    """
    
    response = llm.invoke(critic_prompt)
    critique = parse_json(response.content)

    return {
        **state,
        "reflection_score":       critique["score"],
        "human_approval_needed":  critique["needs_human"],
        "plan": critique.get("revised_plan") or state["plan"],
        "scratchpad": [f"[reflection] score={critique['score']} issues={critique['issues']}"],
        "retry_count": state["retry_count"] + (1 if critique["score"] < 0.5 else 0),
    }
```

