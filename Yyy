## 🗺️ LangGraph Node Wiring

```python
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.memory import MemorySaver

graph = StateGraph(AgentState)

# ── Node registration ──────────────────────────────────────────────
graph.add_node("input_router",     input_router_node)
graph.add_node("supervisor",       supervisor_node)
graph.add_node("memory_retrieve",  memory_retrieve_node)
graph.add_node("planner",          planner_node)
graph.add_node("executor",         executor_node)          # runs tool calls
graph.add_node("parallel_fanout",  parallel_fanout_node)   # async sub-agents
graph.add_node("reflection",       reflection_node)        # self-critic
graph.add_node("human_gate",       human_gate_node)        # interrupt
graph.add_node("output_synth",     output_synth_node)

# ── Entry ──────────────────────────────────────────────────────────
graph.set_entry_point("input_router")

# ── Edges ──────────────────────────────────────────────────────────
graph.add_edge("input_router",    "supervisor")
graph.add_edge("supervisor",      "memory_retrieve")
graph.add_edge("memory_retrieve", "planner")

# Conditional: needs human approval?
graph.add_conditional_edges("planner", route_human_or_exec, {
    "human":    "human_gate",
    "execute":  "executor",
    "parallel": "parallel_fanout",
})

graph.add_edge("human_gate",      "executor")
graph.add_edge("parallel_fanout", "executor")

# Conditional: reflection loop or done?
graph.add_conditional_edges("executor", route_reflection, {
    "reflect":  "reflection",
    "done":     "output_synth",
})

graph.add_conditional_edges("reflection", route_after_reflection, {
    "retry":      "planner",    # re-plan with new info
    "escalate":   "human_gate",
    "done":       "output_synth",
})

graph.add_edge("output_synth", END)

# ── Compile with checkpointing ─────────────────────────────────────
checkpointer = MemorySaver()
app = graph.compile(
    checkpointer=checkpointer,
    interrupt_before=["human_gate"],   # pause for human approval
)
